---
const rows = 4;
const columns = 5;
const tileWidth = 601;
const tileHeight = 416;
const mosaicRatio = (columns * tileWidth) / (rows * tileHeight);
const tiles = Array.from({ length: rows * columns }, (_, index) => ({
	index,
	row: Math.floor(index / columns) + 1,
	col: (index % columns) + 1,
}));
const tileRows = Array.from({ length: rows }, (_, rowIndex) =>
	tiles.slice(rowIndex * columns, (rowIndex + 1) * columns)
);

const frameFolders = ['1', '2'];
const frames = frameFolders.map((folder) =>
	tiles.map((tile) => `/${folder}/${folder}Marlowe_web_images_Marlowe ${tile.row}.${tile.col}.jpg`)
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="https://use.typekit.net/duj0xcr.css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Two Image Flex Mosaic Once</title>
		<meta
			name="description"
			content="A two-frame 4x5 image-set hover prototype where each tile can reveal only once."
		/>
	</head>
	<body>
		<header class="site-header" aria-label="Site header">
			<a class="site-link" href="/menu.pdf">Menu</a>
			<a class="site-logo" href="/" aria-label="Marlowe home">Marlowe</a>
			<a class="site-link site-link--right" href="mailto:book@marlowe.co.nz">Book table</a>
		</header>
		<main class="mosaic-shell" aria-label="Interactive natural-size image mosaic">
			<section
				class="mosaic"
				aria-label="Image fragments arranged with flex rows"
				style={`--rows:${rows}; --columns:${columns}; --mosaic-ratio:${mosaicRatio};`}
			>
				{tileRows.map((row) => (
					<div class="mosaic__row">
						{row.map((tile) => (
							<button
								class="tile"
								type="button"
								data-tile-index={tile.index}
								data-frame="0"
								aria-label={`Reveal image fragment ${tile.index + 1}`}
							>
								<img
									class="tile__image"
									src={frames[0][tile.index]}
									width={tileWidth}
									height={tileHeight}
									alt=""
								/>
								<span class="tile__flash"></span>
							</button>
						))}
					</div>
				))}
			</section>
		</main>
		<footer class="site-footer" aria-label="Site footer">
			<a class="site-footer__contact" href="mailto:book@marlowe.co.nz">book@marlowe.co.nz</a>
			<p class="site-footer__centre">
				211 High Street Christchurch New Zealand<br />
				Open till late, closed on Monday<br />
				&copy; 2026 Marlowe
			</p>
			<a class="site-footer__contact site-footer__contact--right" href="tel:+64221234567">022 123 4567</a>
		</footer>

		<script define:vars={{ frames }}>
			const tiles = [...document.querySelectorAll('.tile')];
			const revealFrame = 1;

			function revealTile(tile) {
				if (tile.dataset.revealed === 'true') return;

				const image = tile.querySelector('.tile__image');
				const tileIndex = Number(tile.dataset.tileIndex);
				tile.dataset.frame = String(revealFrame);
				tile.dataset.revealed = 'true';
				image.src = frames[revealFrame][tileIndex];
				tile.dataset.revealing = 'true';
				window.setTimeout(() => delete tile.dataset.revealing, 420);
			}

			tiles.forEach((tile) => {
				tile.addEventListener('pointerenter', () => revealTile(tile));
				tile.addEventListener('focus', () => revealTile(tile));
				tile.addEventListener('click', () => revealTile(tile));
			});
		</script>
	</body>
</html>

<style>
	:root {
		--focus: #fff7e7;
		background: #111;
		color: #111;
		font-family: neue-haas-grotesk-display, sans-serif;
		font-style: normal;
		font-weight: 500;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		width: 100%;
		min-width: 320px;
		min-height: 100%;
		margin: 0;
		background: #111;
	}

	button {
		font: inherit;
	}

	.site-header,
	.site-footer {
		position: fixed;
		z-index: 10;
		left: 0;
		width: 100%;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		padding: clamp(16px, 2.5vw, 28px);
		color: #fff7e7;
		font-size: clamp(0.78rem, 1vw, 0.95rem);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		pointer-events: none;
	}

	.site-header {
		top: 0;
	}

	.site-footer {
		bottom: 0;
		align-items: end;
	}

	.site-link,
	.site-logo,
	.site-footer__contact {
		width: fit-content;
		color: inherit;
		text-decoration: none;
		pointer-events: auto;
	}

	.site-logo {
		justify-self: center;
		font-family: ivyora-display, serif;
		font-size: clamp(1.1rem, 2vw, 1.7rem);
		font-style: normal;
		font-weight: 400;
		letter-spacing: 0.18em;
	}

	.site-link--right,
	.site-footer__contact--right {
		justify-self: end;
	}

	.site-link,
	.site-footer__contact {
		padding: 0.58rem 0.72rem 0.48rem;
		background: rgba(17, 17, 17, 0.34);
		backdrop-filter: blur(8px);
	}

	.site-link:hover,
	.site-link:focus-visible,
	.site-footer__contact:hover,
	.site-footer__contact:focus-visible {
		text-decoration: underline;
		text-underline-offset: 0.28em;
	}

	.site-footer__centre {
		max-width: 26rem;
		margin: 0;
		color: rgba(255, 247, 231, 0.82);
		font-size: clamp(0.72rem, 0.95vw, 0.86rem);
		line-height: 1.35;
		letter-spacing: 0.06em;
		text-align: center;
		text-transform: uppercase;
	}

	@media (max-width: 640px) {
		.site-header,
		.site-footer {
			padding: 14px;
		}

		.site-footer {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 0.55rem;
		}

		.site-footer__contact,
		.site-footer__contact--right {
			justify-self: center;
		}
	}

	.mosaic-shell {
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		overflow: hidden;
		background:
			radial-gradient(circle at 18% 16%, rgba(255, 247, 231, 0.12), transparent 30%),
			linear-gradient(135deg, #070707, #1a1510 56%, #0b0a08);
	}

	.mosaic {
		--tile-gap: clamp(3px, 0.55vw, 8px);
		--mosaic-padding: clamp(4px, 0.7vw, 10px);
		position: relative;
		flex: 0 0 auto;
		width: max(100vw, calc(100svh * var(--mosaic-ratio)));
		aspect-ratio: var(--mosaic-ratio);
		display: flex;
		flex-direction: column;
		gap: var(--tile-gap);
		padding: var(--mosaic-padding);
		overflow: hidden;
		isolation: isolate;
		background: #181411;
		box-shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
	}

	.mosaic::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0.08), transparent 30%, rgba(0, 0, 0, 0.28)),
			repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.045) 0 1px, transparent 1px 8px);
		opacity: 0.75;
	}

	.mosaic__row {
		display: flex;
		gap: var(--tile-gap);
		width: 100%;
		line-height: 0;
	}

	.tile {
		position: relative;
		display: block;
		flex: 0 0 calc((100% - ((var(--columns) - 1) * var(--tile-gap))) / var(--columns));
		min-width: 0;
		padding: 0;
		border: 0;
		overflow: hidden;
		cursor: crosshair;
		background: transparent;
		box-shadow:
			0 1px 2px rgba(0, 0, 0, 0.2),
			0 4px 12px rgba(0, 0, 0, 0.22);
		line-height: 0;
	}

	.tile:focus-visible {
		z-index: 5;
		outline: 3px solid var(--focus);
		outline-offset: -7px;
	}

	.tile__image {
		display: block;
		width: 100%;
		height: auto;
		filter: contrast(1.05) saturate(0.86) grayscale(0.1);
		transform: translate3d(0, 0, 0) scale(1.01);
		transition: filter 160ms steps(2, end);
		user-select: none;
		pointer-events: none;
	}

	.tile:hover .tile__image,
	.tile:focus-visible .tile__image,
	.tile[data-revealing] .tile__image {
		animation: stop-pop 340ms steps(3, end);
		filter: contrast(1.18) saturate(1.04);
	}

	.tile__flash {
		position: absolute;
		inset: 0;
		display: block;
		background: #fff7e7;
		opacity: 0;
		mix-blend-mode: screen;
		pointer-events: none;
	}

	.tile[data-revealing] .tile__flash {
		animation: flash-frame 340ms steps(2, end);
	}

	@keyframes stop-pop {
		0% {
			transform: translate3d(-1%, 1%, 0) scale(1.035);
		}

		48% {
			transform: translate3d(1%, -1%, 0) scale(1.01);
		}

		100% {
			transform: translate3d(0, 0, 0) scale(1.02);
		}
	}

	@keyframes flash-frame {
		0%,
		100% {
			opacity: 0;
		}

		36% {
			opacity: 0.34;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 1ms !important;
			animation-iteration-count: 1 !important;
			scroll-behavior: auto !important;
			transition-duration: 1ms !important;
		}
	}
</style>
