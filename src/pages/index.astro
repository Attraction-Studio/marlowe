---
import '../styles/home.css';

const rows = 4;
const columns = 5;
const tileWidth = 601;
const tileHeight = 416;
const mosaicRatio = (columns * tileWidth) / (rows * tileHeight);
const jitterPattern: [number, number, number, string, string][] = [
	[-0.68, -0.16, 0.1, '36%', '42%'],
	[0.56, 0.12, -0.12, '54%', '45%'],
	[-0.44, 0.08, 0.14, '42%', '55%'],
	[0.74, -0.1, -0.08, '58%', '40%'],
	[-0.52, 0.14, 0.1, '46%', '58%'],
];
const tiles = Array.from({ length: rows * columns }, (_, index) => {
	const row = Math.floor(index / columns) + 1;
	const col = (index % columns) + 1;
	const jitter = jitterPattern[index % jitterPattern.length];
	const centerCol = (columns + 1) / 2;
	const centerRow = (rows + 1) / 2;
	const side = col < centerCol ? -1 : col > centerCol ? 1 : index % 2 === 0 ? -1 : 1;
	const vertical = row < centerRow ? -1 : row > centerRow ? 1 : index % 3 === 0 ? -1 : 1;

	return {
		index,
		row,
		col,
		tilt: `${jitter[0]}deg`,
		shiftX: `${jitter[1]}%`,
		shiftY: `${jitter[2]}%`,
		originX: jitter[3],
		originY: jitter[4],
		menuX: `${side * (34 + Math.abs(col - centerCol) * 11 + (index % 4) * 3)}vw`,
		menuY: `${vertical * (18 + Math.abs(row - centerRow) * 10 + (index % 5) * 2)}vh`,
		menuTilt: `${side * (10 + (index % 7) * 4)}deg`,
		menuDelay: `${(index % 6) * 22}ms`,
		eventX: `${-46 - col * 2.8}vw`,
		eventY: `${(row - centerRow) * 1.8}vh`,
		eventTilt: `${jitter[0] * 0.28}deg`,
		eventDelay: `${(col - 1) * 34 + (row - 1) * 14}ms`,
	};
});
const tileRows = Array.from({ length: rows }, (_, rowIndex) =>
	tiles.slice(rowIndex * columns, (rowIndex + 1) * columns)
);

const frameFolders = ['1', '2'];
const imageModules = import.meta.glob<string>('../images/{1,2}/*.webp', {
	eager: true,
	query: '?url',
	import: 'default',
});
const imageLookup = new Map<string, string>();

Object.entries(imageModules).forEach(([path, src]) => {
	const match = path.match(/images\/(?<folder>[12])\/.*Marlowe (?<row>\d)\.(?<col>\d)\.webp$/);

	if (!match?.groups) return;

	imageLookup.set(`${match.groups.folder}-${match.groups.row}-${match.groups.col}`, src);
});

const frames = frameFolders.map((folder) =>
	tiles.map((tile) => {
		const src = imageLookup.get(`${folder}-${tile.row}-${tile.col}`);

		if (!src) {
			throw new Error(`Missing mosaic image for frame ${folder}, row ${tile.row}, column ${tile.col}`);
		}

		return src;
	})
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="https://use.typekit.net/duj0xcr.css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Marlowe Site Draft</title>
		<meta
			name="description"
			content="A two-frame 4x5 image-set hover prototype where the mosaic scatters to reveal a menu."
		/>
	</head>
	<body>
		<header class="site-header" aria-label="Site header">
			<button
				class="site-link site-link--button"
				type="button"
				aria-controls="menu-panel"
				aria-expanded="false"
				data-menu-toggle
			>
				VIEW <span class="text-serif">MENU</span>
			</button>
			<a class="site-logo" href="/" aria-label="Marlowe">
				<span class="site-logo__mark" aria-hidden="true"></span>
			</a>
			<button
				class="site-link site-link--button site-link--right"
				type="button"
				aria-controls="event-panel"
				aria-expanded="false"
				data-event-toggle
			>
				WHAT'S <span class="text-serif">ON</span>
			</button>
		</header>
		<main class="mosaic-shell" aria-label="Interactive natural-size image mosaic">
			<section
				class="mosaic"
				aria-label="Image fragments arranged with flex rows"
				style={`--rows:${rows}; --columns:${columns}; --mosaic-ratio:${mosaicRatio};`}
			>
				{tileRows.map((row) => (
					<div class="mosaic__row">
						{row.map((tile) => (
							<button
								class="tile"
								type="button"
								data-tile-index={tile.index}
								data-tile-col={tile.col}
								data-frame="0"
								style={`--tilt:${tile.tilt}; --shift-x:${tile.shiftX}; --shift-y:${tile.shiftY}; --origin-x:${tile.originX}; --origin-y:${tile.originY}; --menu-x:${tile.menuX}; --menu-y:${tile.menuY}; --menu-tilt:${tile.menuTilt}; --menu-delay:${tile.menuDelay}; --event-x:${tile.eventX}; --event-y:${tile.eventY}; --event-tilt:${tile.eventTilt}; --event-delay:${tile.eventDelay};`}
								aria-label={`Reveal image fragment ${tile.index + 1}`}
							>
								<img
									class="tile__image"
									src={frames[0][tile.index]}
									width={tileWidth}
									height={tileHeight}
									alt=""
								/>
								<span class="tile__flash"></span>
							</button>
						))}
					</div>
				))}
			</section>
		</main>
		<aside class="menu-panel" id="menu-panel" aria-label="Marlowe menu" aria-hidden="true">
			<nav class="menu-panel__inner menu-panel__inner--image" aria-label="Marlowe menu image">
				<!--
					Archived interactive menu layout for restoration after client review:
					<p class="menu-panel__kicker">MENUS</p>
					<div class="menu-panel__preview" aria-hidden="true">
						<img src="/menu-draft.jpg" alt="" data-menu-preview-image />
					</div>
					<div class="menu-panel__links">
						<a class="menu-panel__item is-active" href="/menu-draft.jpg" target="_blank" rel="noopener noreferrer" data-menu-item data-preview="/menu-draft.jpg" style="--item-index: 0; --item-x: 14vw;">
							<span>01.</span>
							<strong>BREAKFAST</strong>
						</a>
						<a class="menu-panel__item" href="/menu-draft.jpg" target="_blank" rel="noopener noreferrer" data-menu-item data-preview="/menu-draft.jpg" style="--item-index: 1; --item-x: 28vw;">
							<span>02.</span>
							<strong>LUNCH</strong>
						</a>
						<a class="menu-panel__item" href="/menu-draft.jpg" target="_blank" rel="noopener noreferrer" data-menu-item data-preview="/menu-draft.jpg" style="--item-index: 2; --item-x: 7vw;">
							<span>03.</span>
							<strong>DINNER</strong>
						</a>
						<a class="menu-panel__item" href="/menu-draft.jpg" target="_blank" rel="noopener noreferrer" data-menu-item data-preview="/menu-draft.jpg" style="--item-index: 3; --item-x: 45vw;">
							<span>04.</span>
							<strong>DRINKS</strong>
						</a>
					</div>
					<p class="menu-panel__meta">211 HIGH STREET CHRISTCHURCH / OPEN TILL LATE</p>
				-->
				<a class="menu-panel__menu-sheet" href="/Marlowe_menu.png" target="_blank" rel="noopener noreferrer">
					<img src="/Marlowe_menu.png" alt="MARLOWE MENU" />
				</a>
			</nav>
		</aside>
		<aside class="event-panel" id="event-panel" aria-label="What's on at Marlowe" aria-hidden="true">
			<div class="event-panel__inner">
				<div class="event-panel__content">
					<p class="event-panel__partner">Upcoming Event</p>
					<h2>Marlowe x Rambler</h2>
					<p class="event-panel__description">
A one-night collaboration between Marlowe & Rambler, led by Marlowe's Head Chef Olly Le Maitre, bringing together a seasonal menu, a specially curated evening, and relaxed hospitality from both teams.
</p>

<p class="event-panel__description">
	Expect seasonal dishes, a bespoke drinks list curated by Rambler, and a first taste of what Marlowe is all about.
</p>
					<dl class="event-panel__details">
						<div>
							<dt>Date</dt>
							<dd>Thursday 13th August, 2026</dd>
						</div>
						<div>
							<dt>Time</dt>
							<dd>6:00 PM - late</dd>
						</div>
						<div>
							<dt>Location</dt>
							<dd>96 Lichfield Street, Christchurch Central City, Christchurch 8011</dd>
						</div>
						<div>
							<dt>Price</dt>
							<dd>$75pp set menu, Three courses</dd>
						</div>
					</dl>
				</div>
			</div>
		</aside>
		<footer class="site-footer" aria-label="Site footer">
			<a class="site-footer__contact" href="mailto:hello@marlowe.co.nz">hello@<span class="text-serif">MARLOWE.CO.NZ</span></a>
			<p class="site-footer__centre">
				211 HIGH STREET<br />
				CHRISTCHURCH, <span class="text-serif">NEW ZEALAND</span><br />
				OPEN TILL LATE, <span class="text-serif">CLOSED ON MONDAY</span><br />
				&copy; 2026 MARLOWE
			</p>
			<a class="site-footer__contact site-footer__contact--right" href="tel:+64221234567">022 123 4567</a>
		</footer>

		<script define:vars={{ frames }}>
			const tiles = [...document.querySelectorAll('.tile')];
			const menuToggle = document.querySelector('[data-menu-toggle]');
			const menuPanel = document.querySelector('#menu-panel');
			const eventToggle = document.querySelector('[data-event-toggle]');
			const eventPanel = document.querySelector('#event-panel');
			const menuItems = [...document.querySelectorAll('[data-menu-item]')];
			const menuPreviewImage = document.querySelector('[data-menu-preview-image]');
			const mobileSwapQuery = window.matchMedia('(max-width: 640px)');
			const revealFrame = 1;
			let menuCloseTimer;
			let eventCloseTimer;
			let mobileSwapTimer;
			let mobileSwapIndex = 0;

			function revealTile(tile) {
				if (tile.dataset.revealed === 'true') return;

				const image = tile.querySelector('.tile__image');
				const tileIndex = Number(tile.dataset.tileIndex);
				tile.dataset.frame = String(revealFrame);
				tile.dataset.revealed = 'true';
				image.src = frames[revealFrame][tileIndex];
				tile.dataset.revealing = 'true';
				window.setTimeout(() => delete tile.dataset.revealing, 420);
			}

			tiles.forEach((tile) => {
				tile.addEventListener('pointerenter', () => revealTile(tile));
				tile.addEventListener('focus', () => revealTile(tile));
				tile.addEventListener('click', () => revealTile(tile));
			});

			const mobileSwapTiles = tiles.filter((tile) => {
				const column = Number(tile.dataset.tileCol);
				return column > 1 && column < 5;
			});

			function stopMobileAutoSwap() {
				window.clearTimeout(mobileSwapTimer);
				mobileSwapTimer = undefined;
				mobileSwapIndex = 0;
			}

			function queueMobileAutoSwap() {
				window.clearTimeout(mobileSwapTimer);

				if (!mobileSwapQuery.matches || mobileSwapIndex >= mobileSwapTiles.length) return;

				mobileSwapTimer = window.setTimeout(() => {
					revealTile(mobileSwapTiles[mobileSwapIndex]);
					mobileSwapIndex += 1;
					queueMobileAutoSwap();
				}, mobileSwapIndex === 0 ? 520 : 760);
			}

			function syncMobileAutoSwap() {
				if (mobileSwapQuery.matches) {
					queueMobileAutoSwap();
				} else {
					stopMobileAutoSwap();
				}
			}

			syncMobileAutoSwap();
			mobileSwapQuery.addEventListener('change', syncMobileAutoSwap);

			function closeMenu() {
				window.clearTimeout(menuCloseTimer);
				document.body.dataset.menuOpen = 'false';
				document.body.dataset.menuClosing = 'true';
				menuCloseTimer = window.setTimeout(() => {
					delete document.body.dataset.menuClosing;
				}, 860);
				menuToggle?.setAttribute('aria-expanded', 'false');
				if (menuToggle) menuToggle.innerHTML = 'VIEW <span class="text-serif">MENU</span>';
				menuPanel?.setAttribute('aria-hidden', 'true');
			}

			function closeEvent() {
				window.clearTimeout(eventCloseTimer);
				document.body.dataset.eventOpen = 'false';
				document.body.dataset.eventClosing = 'true';
				eventCloseTimer = window.setTimeout(() => {
					delete document.body.dataset.eventClosing;
				}, 860);
				eventToggle?.setAttribute('aria-expanded', 'false');
				if (eventToggle) eventToggle.innerHTML = "WHAT'S <span class=\"text-serif\">ON</span>";
				eventPanel?.setAttribute('aria-hidden', 'true');
			}

			menuToggle?.addEventListener('click', () => {
				const isOpen = document.body.dataset.menuOpen === 'true';
				window.clearTimeout(menuCloseTimer);

				if (isOpen) {
					closeMenu();
				} else {
					if (document.body.dataset.eventOpen === 'true') closeEvent();
					delete document.body.dataset.eventClosing;
					delete document.body.dataset.menuClosing;
					document.body.dataset.menuOpen = 'true';
					menuToggle.setAttribute('aria-expanded', 'true');
					menuToggle.textContent = 'CLOSE';
					menuPanel?.setAttribute('aria-hidden', 'false');
				}
			});

			eventToggle?.addEventListener('click', () => {
				const isOpen = document.body.dataset.eventOpen === 'true';
				window.clearTimeout(eventCloseTimer);

				if (isOpen) {
					closeEvent();
				} else {
					if (document.body.dataset.menuOpen === 'true') closeMenu();
					delete document.body.dataset.menuClosing;
					delete document.body.dataset.eventClosing;
					document.body.dataset.eventOpen = 'true';
					eventToggle.setAttribute('aria-expanded', 'true');
					eventToggle.textContent = 'CLOSE';
					eventPanel?.setAttribute('aria-hidden', 'false');
				}
			});

			function setActiveMenuItem(activeItem) {
				menuItems.forEach((item) => {
					item.classList.toggle('is-active', item === activeItem);
				});

				if (menuPreviewImage && activeItem?.dataset.preview) {
					menuPreviewImage.src = activeItem.dataset.preview;
				}
			}

			menuItems.forEach((item) => {
				item.addEventListener('pointerenter', () => setActiveMenuItem(item));
				item.addEventListener('focus', () => setActiveMenuItem(item));
			});
		</script>
	</body>
</html>
