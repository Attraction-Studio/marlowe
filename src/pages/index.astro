---
import '../styles/home.css';
import aboutOwnersLandscape from '../images/about/Olly Le Maitre and Santiago Burgos Landscape.webp';

const rows = 4;
const columns = 5;
const tileWidth = 601;
const tileHeight = 416;
const mosaicRatio = (columns * tileWidth) / (rows * tileHeight);
const jitterPattern: [number, number, number, string, string][] = [
	[-0.68, -0.16, 0.1, '36%', '42%'],
	[0.56, 0.12, -0.12, '54%', '45%'],
	[-0.44, 0.08, 0.14, '42%', '55%'],
	[0.74, -0.1, -0.08, '58%', '40%'],
	[-0.52, 0.14, 0.1, '46%', '58%'],
];
const tiles = Array.from({ length: rows * columns }, (_, index) => {
	const row = Math.floor(index / columns) + 1;
	const col = (index % columns) + 1;
	const jitter = jitterPattern[index % jitterPattern.length];
	const centerCol = (columns + 1) / 2;
	const centerRow = (rows + 1) / 2;
	const side = col < centerCol ? -1 : col > centerCol ? 1 : index % 2 === 0 ? -1 : 1;
	const vertical = row < centerRow ? -1 : row > centerRow ? 1 : index % 3 === 0 ? -1 : 1;

	return {
		index,
		row,
		col,
		tilt: `${jitter[0]}deg`,
		shiftX: `${jitter[1]}%`,
		shiftY: `${jitter[2]}%`,
		originX: jitter[3],
		originY: jitter[4],
		menuX: `${side * (34 + Math.abs(col - centerCol) * 11 + (index % 4) * 3)}vw`,
		menuY: `${vertical * (18 + Math.abs(row - centerRow) * 10 + (index % 5) * 2)}vh`,
		menuTilt: `${side * (10 + (index % 7) * 4)}deg`,
		menuDelay: `${(index % 6) * 22}ms`,
		eventX: `${-46 - col * 2.8}vw`,
		eventY: `${(row - centerRow) * 1.8}vh`,
		eventTilt: `${jitter[0] * 0.28}deg`,
		eventDelay: `${(col - 1) * 34 + (row - 1) * 14}ms`,
	};
});
const tileRows = Array.from({ length: rows }, (_, rowIndex) =>
	tiles.slice(rowIndex * columns, (rowIndex + 1) * columns)
);

const frameFolders = ['1', '2'];
const imageModules = import.meta.glob<string>('../images/{1,2}/*.webp', {
	eager: true,
	query: '?url',
	import: 'default',
});
const imageLookup = new Map<string, string>();

Object.entries(imageModules).forEach(([path, src]) => {
	const match = path.match(/images\/(?<folder>[12])\/.*Marlowe (?<row>\d)\.(?<col>\d)\.webp$/);

	if (!match?.groups) return;

	imageLookup.set(`${match.groups.folder}-${match.groups.row}-${match.groups.col}`, src);
});

const frames = frameFolders.map((folder) =>
	tiles.map((tile) => {
		const src = imageLookup.get(`${folder}-${tile.row}-${tile.col}`);

		if (!src) {
			throw new Error(`Missing mosaic image for frame ${folder}, row ${tile.row}, column ${tile.col}`);
		}

		return src;
	})
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="https://use.typekit.net/duj0xcr.css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Marlowe Site Draft</title>
		<meta
			name="description"
			content="A two-frame 4x5 image-set hover prototype where the mosaic scatters to reveal a menu."
		/>
	</head>
	<body>
		<header class="site-header" aria-label="Site header">
			<button
				class="site-link site-link--button"
				type="button"
				aria-controls="menu-panel"
				aria-expanded="false"
				data-menu-toggle
			>
				VIEW <span class="text-serif">MENU</span>
			</button>
			<a class="site-logo" href="/" aria-label="Marlowe">
				<span class="site-logo__mark" aria-hidden="true"></span>
			</a>
			<button
				class="site-link site-link--button site-link--right"
				type="button"
				aria-controls="event-panel"
				aria-expanded="false"
				data-event-toggle
			>
				WHAT'S <span class="text-serif">ON</span>
			</button>
		</header>
		<main class="mosaic-shell" aria-label="Interactive natural-size image mosaic">
			<section
				class="mosaic"
				aria-label="Image fragments arranged with flex rows"
				style={`--rows:${rows}; --columns:${columns}; --mosaic-ratio:${mosaicRatio};`}
			>
				{tileRows.map((row) => (
					<div class="mosaic__row">
						{row.map((tile) => (
							<button
								class="tile"
								type="button"
								data-tile-index={tile.index}
								data-tile-col={tile.col}
								data-frame="0"
								style={`--tilt:${tile.tilt}; --shift-x:${tile.shiftX}; --shift-y:${tile.shiftY}; --origin-x:${tile.originX}; --origin-y:${tile.originY}; --menu-x:${tile.menuX}; --menu-y:${tile.menuY}; --menu-tilt:${tile.menuTilt}; --menu-delay:${tile.menuDelay}; --event-x:${tile.eventX}; --event-y:${tile.eventY}; --event-tilt:${tile.eventTilt}; --event-delay:${tile.eventDelay};`}
								aria-label={`Reveal image fragment ${tile.index + 1}`}
							>
								<img
									class="tile__image"
									src={frames[0][tile.index]}
									width={tileWidth}
									height={tileHeight}
									alt=""
								/>
								<span class="tile__flash"></span>
							</button>
						))}
					</div>
				))}
			</section>
		</main>
		<aside class="menu-panel" id="menu-panel" aria-label="Marlowe menu" aria-hidden="true">
			<nav class="menu-panel__inner menu-panel__inner--image" aria-label="Marlowe menu image">
				<a class="menu-panel__menu-sheet" href="/Marlowe_menu.png" target="_blank" rel="noopener noreferrer">
					<img src="/Marlowe_menu.png" alt="MARLOWE MENU" />
				</a>
			</nav>
		</aside>
		<aside class="menu-panel" id="explore-panel" aria-label="Explore Marlowe menus" aria-hidden="true">
			<nav class="menu-panel__inner" aria-label="Explore Marlowe menus">
				<div class="menu-panel__links" data-explore-track>
					<button class="menu-panel__item is-active" type="button" data-explore-item="careers" style="--item-index: 0;">
						<strong>Careers</strong>
					</button>
					<button class="menu-panel__item" type="button" data-explore-item="about" style="--item-index: 1;">
						<strong>About Us</strong>
					</button>
					<button class="menu-panel__item" type="button" data-explore-item="enquiries" style="--item-index: 2;">
						<strong>Contact</strong>
					</button>
					<button class="menu-panel__item" type="button" data-explore-item="bookings" style="--item-index: 3;">
						<strong>Bookings Coming Soon</strong>
					</button>
				</div>
				<div class="explore-panel__content" data-explore-content-wrap>
					<article class="explore-panel__section is-active" data-explore-content="careers">
						<p class="explore-panel__eyebrow">Careers</p>
						<h2>Work with us</h2>
						<p class="explore-panel__intro">New jobs coming soon.</p>
						<p>
							We're building a team of people who genuinely care — about food, about hospitality, and about
							making every guest feel like they're in good hands. If that sounds like you, we'd love to hear
							from you.
						</p>
						<div class="explore-panel__role">
							<h3>Kitchen</h3>
							<p>
								To enquire about a position with the Marlowe kitchen team, send your CV and a brief cover note to
								<a href="mailto:olly@marlowe.co.nz">olly@marlowe.co.nz</a>
							</p>
						</div>
						<div class="explore-panel__role">
							<h3>Front of House & Bar</h3>
							<p>
								To apply for a role in our service or bar team, send your CV and cover letter to
								<a href="mailto:santi@marlowe.co.nz">santi@marlowe.co.nz</a>
							</p>
						</div>
					</article>
					<article class="explore-panel__section" data-explore-content="about">
						<p class="explore-panel__eyebrow">About Us</p>
						<h2>Olly Le Maitre & Santiago Burgos</h2>
						<figure class="explore-panel__media">
							<img
								src={aboutOwnersLandscape.src}
								width={aboutOwnersLandscape.width}
								height={aboutOwnersLandscape.height}
								alt="Olly Le Maitre and Santiago Burgos seated together"
								loading="lazy"
							/>
						</figure>
						<p>
							Marlowe was founded by Olly Le Maitre and Santiago Burgos, brought together by a shared belief that
							great hospitality is about making people feel like they're in good hands from the moment they walk
							through the door.
						</p>
						<p>
							Opening this September on High Street, Marlowe is an independently owned restaurant built around
							exceptional New Zealand produce, thoughtful service, and a genuine love of bringing people together.
							Our food is vibrant, flavour-driven and inspired by timeless European cooking, while our wine and
							drinks programme celebrates both New Zealand and the great wine regions of the world.
						</p>
						<p>
							Whether you're joining us for a quick bite and a glass of wine, a long lunch with friends, or a
							special dinner, our aim is simple: to create a place that feels warm, familiar and effortlessly
							welcoming, somewhere you'll want to return to again and again.
						</p>
					</article>
					<article class="explore-panel__section" data-explore-content="enquiries">
						<p class="explore-panel__eyebrow">General Enquiries</p>
						<h2>Talk to us</h2>
						<p>
							For event questions, supplier conversations, press, or anything that needs a human reply, send us a
							note and the right person will come back to you.
						</p>
						<a href="mailto:hello@marlowe.co.nz,santiago@marlowe.co.nz" class="explore-panel__link">
							Email Marlowe
						</a>
					</article>
					<article class="explore-panel__section" data-explore-content="bookings">
						<p class="explore-panel__eyebrow">Bookings Coming Soon</p>
						<h2>Tables are nearly ready</h2>
						<p>
							Bookings for regular service will open soon. For now, keep an eye on the site for updates and use
							What's On for special event reservations.
						</p>
					</article>
				</div>
			</nav>
		</aside>
		<aside class="event-panel" id="event-panel" aria-label="What's on at Marlowe" aria-hidden="true">
			<div class="event-panel__inner">
				<div class="event-panel__content">
					<p class="event-panel__partner">Upcoming Event</p>
					<h2>Marlowe x Rambler</h2>
					<p class="event-panel__description">
A one-night collaboration between Marlowe & Rambler, led by Marlowe's Head Chef Olly Le Maitre, bringing together a seasonal menu, a specially curated evening, and relaxed hospitality from both teams.
</p>

<p class="event-panel__description">
	Expect seasonal dishes, a bespoke drinks list curated by Rambler, and a first taste of what Marlowe is all about.
</p>
					<dl class="event-panel__details">
						<div>
							<dt>Date</dt>
							<dd>Thursday 13th August, 2026</dd>
						</div>
						<div>
							<dt>Time</dt>
							<dd>6:00 PM - late</dd>
						</div>
						<div>
							<dt>Location</dt>
							<dd>96 Lichfield Street, Christchurch Central City, Christchurch 8011</dd>
						</div>
						<div>
							<dt>Price</dt>
							<dd>$75pp set menu, Three courses</dd>
						</div>
					</dl>
					<a
						class="event-panel__booking"
						href="https://bookings.nowbookit.com/?accountid=e4eee640-ce69-4dcb-addb-89538782114f&theme=light&accent=hex,006064,f57f17&venueid=12302&date=2026-08-13&serviceids=event_53KHA44PJFO1H_1783047417957"
						target="_blank"
						rel="noopener noreferrer"
					>
						Book <span class="text-serif">Now</span>
					</a>
				</div>
			</div>
		</aside>
		<footer class="site-footer" aria-label="Site footer">
			<div class="site-footer__contacts">
				<a class="site-footer__contact site-footer__contact--right" href="tel:+64221234567">022 123 4567</a>
				<a class="site-footer__contact" href="mailto:hello@marlowe.co.nz,santiago@marlowe.co.nz">General <span class="text-serif">Enquiries</span></a>
			</div>
			<p class="site-footer__centre">
				<span class="site-footer__notice" aria-label="Bookings coming soon">
					<span>Bookings Coming Soon</span>
				</span>
				211 HIGH STREET<br />
				CHRISTCHURCH, <span class="text-serif">NEW ZEALAND</span><br />
				OPEN TILL LATE, <span class="text-serif">CLOSED ON MONDAY</span><br />
				&copy; 2026 MARLOWE
			</p>
			<button
				class="site-footer__contact site-footer__contact--right"
				type="button"
				aria-controls="explore-panel"
				aria-expanded="false"
				data-explore-toggle
			>
				EXPLORE
			</button>
		</footer>

		<script define:vars={{ frames }}>
			const tiles = [...document.querySelectorAll('.tile')];
			const menuToggles = [...document.querySelectorAll('[data-menu-toggle]')];
			const menuPanel = document.querySelector('#menu-panel');
			const exploreToggles = [...document.querySelectorAll('[data-explore-toggle]')];
			const explorePanel = document.querySelector('#explore-panel');
			const exploreTrack = document.querySelector('[data-explore-track]');
			const exploreItems = [...document.querySelectorAll('[data-explore-item]')];
			const exploreContents = [...document.querySelectorAll('[data-explore-content]')];
			const eventToggles = [...document.querySelectorAll('[data-event-toggle]')];
			const eventPanel = document.querySelector('#event-panel');
			const menuItems = [...document.querySelectorAll('[data-menu-item]')];
			const menuPreviewImage = document.querySelector('[data-menu-preview-image]');
			const mobileSwapQuery = window.matchMedia('(max-width: 640px)');
			const revealFrame = 1;
			let menuCloseTimer;
			let exploreCloseTimer;
			let eventCloseTimer;
			let mobileSwapTimer;
			let mobileSwapIndex = 0;

			[...menuToggles, ...exploreToggles, ...eventToggles].forEach((toggle) => {
				toggle.dataset.closedLabel = toggle.innerHTML;
			});

			function setToggleState(toggles, isOpen) {
				toggles.forEach((toggle) => {
					toggle.setAttribute('aria-expanded', String(isOpen));
					toggle.innerHTML = isOpen ? 'CLOSE' : toggle.dataset.closedLabel;
				});
			}

			function revealTile(tile) {
				if (tile.dataset.revealed === 'true') return;

				const image = tile.querySelector('.tile__image');
				const tileIndex = Number(tile.dataset.tileIndex);
				tile.dataset.frame = String(revealFrame);
				tile.dataset.revealed = 'true';
				image.src = frames[revealFrame][tileIndex];
				tile.dataset.revealing = 'true';
				window.setTimeout(() => delete tile.dataset.revealing, 420);
			}

			tiles.forEach((tile) => {
				tile.addEventListener('pointerenter', () => revealTile(tile));
				tile.addEventListener('focus', () => revealTile(tile));
				tile.addEventListener('click', () => revealTile(tile));
			});

			const mobileSwapTiles = tiles.filter((tile) => {
				const column = Number(tile.dataset.tileCol);
				return column > 1 && column < 5;
			});

			function stopMobileAutoSwap() {
				window.clearTimeout(mobileSwapTimer);
				mobileSwapTimer = undefined;
				mobileSwapIndex = 0;
			}

			function queueMobileAutoSwap() {
				window.clearTimeout(mobileSwapTimer);

				if (!mobileSwapQuery.matches || mobileSwapIndex >= mobileSwapTiles.length) return;

				mobileSwapTimer = window.setTimeout(() => {
					revealTile(mobileSwapTiles[mobileSwapIndex]);
					mobileSwapIndex += 1;
					queueMobileAutoSwap();
				}, mobileSwapIndex === 0 ? 520 : 760);
			}

			function syncMobileAutoSwap() {
				if (mobileSwapQuery.matches) {
					queueMobileAutoSwap();
				} else {
					stopMobileAutoSwap();
				}
			}

			syncMobileAutoSwap();
			mobileSwapQuery.addEventListener('change', syncMobileAutoSwap);

			function closeMenu() {
				window.clearTimeout(menuCloseTimer);
				document.body.dataset.menuOpen = 'false';
				document.body.dataset.menuClosing = 'true';
				menuCloseTimer = window.setTimeout(() => {
					delete document.body.dataset.menuClosing;
				}, 860);
				setToggleState(menuToggles, false);
				menuPanel?.setAttribute('aria-hidden', 'true');
			}

			function closeExplore() {
				window.clearTimeout(exploreCloseTimer);
				document.body.dataset.exploreOpen = 'false';
				document.body.dataset.exploreClosing = 'true';
				exploreCloseTimer = window.setTimeout(() => {
					delete document.body.dataset.exploreClosing;
				}, 860);
				setToggleState(exploreToggles, false);
				explorePanel?.setAttribute('aria-hidden', 'true');
			}

			function selectExploreItem(item) {
				const target = item.dataset.exploreItem;
				explorePanel.dataset.exploreSelected = 'true';

				exploreItems.forEach((candidate) => {
					const isActive = candidate === item;
					candidate.classList.toggle('is-active', isActive);
					candidate.setAttribute('aria-pressed', String(isActive));
				});

				exploreContents.forEach((content) => {
					content.classList.toggle('is-active', content.dataset.exploreContent === target);
				});
			}

			function syncExploreCursor(event) {
				if (
					!exploreTrack ||
					window.matchMedia('(max-width: 820px)').matches ||
					explorePanel?.dataset.exploreSelected === 'true'
				) return;

				const panelInner = explorePanel?.querySelector('.menu-panel__inner');
				const panelRect = panelInner?.getBoundingClientRect();
				if (!panelRect) return;

				const styles = window.getComputedStyle(panelInner);
				const leftInset = Number.parseFloat(styles.paddingLeft) || 0;
				const rightInset = Number.parseFloat(styles.paddingRight) || 0;
				const visibleWidth = Math.max(panelRect.width - leftInset - rightInset, 1);
				const overflow = Math.max(exploreTrack.offsetWidth - visibleWidth, 0);
				const progress = Math.min(Math.max((event.clientX - panelRect.left) / panelRect.width, 0), 1);
				exploreTrack.style.setProperty('--explore-shift', `${-overflow * progress}px`);
			}

			function closeEvent() {
				window.clearTimeout(eventCloseTimer);
				document.body.dataset.eventOpen = 'false';
				document.body.dataset.eventClosing = 'true';
				eventCloseTimer = window.setTimeout(() => {
					delete document.body.dataset.eventClosing;
				}, 860);
				setToggleState(eventToggles, false);
				eventPanel?.setAttribute('aria-hidden', 'true');
			}

			menuToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const isOpen = document.body.dataset.menuOpen === 'true';
					window.clearTimeout(menuCloseTimer);

					if (isOpen) {
						closeMenu();
					} else {
						if (document.body.dataset.exploreOpen === 'true') closeExplore();
						if (document.body.dataset.eventOpen === 'true') closeEvent();
						delete document.body.dataset.exploreClosing;
						delete document.body.dataset.eventClosing;
						delete document.body.dataset.menuClosing;
						document.body.dataset.menuOpen = 'true';
						setToggleState(menuToggles, true);
						menuPanel?.setAttribute('aria-hidden', 'false');
					}
				});
			});

			exploreToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const isOpen = document.body.dataset.exploreOpen === 'true';
					window.clearTimeout(exploreCloseTimer);

					if (isOpen) {
						closeExplore();
					} else {
						if (document.body.dataset.menuOpen === 'true') closeMenu();
						if (document.body.dataset.eventOpen === 'true') closeEvent();
						delete document.body.dataset.menuClosing;
						delete document.body.dataset.eventClosing;
						delete document.body.dataset.exploreClosing;
						document.body.dataset.exploreOpen = 'true';
						exploreTrack?.style.setProperty('--explore-shift', '0px');
						setToggleState(exploreToggles, true);
						explorePanel?.setAttribute('aria-hidden', 'false');
					}
				});
			});

			eventToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const isOpen = document.body.dataset.eventOpen === 'true';
					window.clearTimeout(eventCloseTimer);

					if (isOpen) {
						closeEvent();
					} else {
						if (document.body.dataset.menuOpen === 'true') closeMenu();
						if (document.body.dataset.exploreOpen === 'true') closeExplore();
						delete document.body.dataset.menuClosing;
						delete document.body.dataset.exploreClosing;
						delete document.body.dataset.eventClosing;
						document.body.dataset.eventOpen = 'true';
						setToggleState(eventToggles, true);
						eventPanel?.setAttribute('aria-hidden', 'false');
					}
				});
			});

			function setActiveMenuItem(activeItem) {
				menuItems.forEach((item) => {
					item.classList.toggle('is-active', item === activeItem);
				});

				if (menuPreviewImage && activeItem?.dataset.preview) {
					menuPreviewImage.src = activeItem.dataset.preview;
				}
			}

			menuItems.forEach((item) => {
				item.addEventListener('pointerenter', () => setActiveMenuItem(item));
				item.addEventListener('focus', () => setActiveMenuItem(item));
			});

			exploreItems.forEach((item) => {
				item.setAttribute('aria-pressed', String(item.classList.contains('is-active')));
				item.addEventListener('click', () => selectExploreItem(item));
			});

			explorePanel?.addEventListener('pointermove', syncExploreCursor);
		</script>
	</body>
</html>
