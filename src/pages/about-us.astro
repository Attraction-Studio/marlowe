---
import '../styles/about.css';
import ownersPortrait from '../images/about/Olly Le Maitre and Santiago Burgos Portrait.webp';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="https://use.typekit.net/duj0xcr.css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>About Us | Marlowe</title>
		<meta
			name="description"
			content="Meet Olly Le Maitre and Santiago Burgos, the founders behind Marlowe on High Street in Christchurch."
		/>
	</head>
	<body class="about-page">
		<script>
			if (window.sessionStorage?.getItem('marloweTransition') === 'to-about') {
				document.body.dataset.pageEnter = 'from-home';
				window.sessionStorage.removeItem('marloweTransition');
			}
		</script>
		<header class="about-header" aria-label="About page header">
			<a class="about-header__link" href="/" data-about-exit>Back <span>Home</span></a>
			<a class="about-header__logo" href="/" aria-label="Marlowe home" data-about-exit>
				<span aria-hidden="true"></span>
			</a>
			<a class="about-header__link about-header__link--right" href="mailto:santiago@marlowe.co.nz?subject=General%20Enquiry">
				Get <span>In Touch</span>
			</a>
		</header>

		<main class="about-story" aria-label="About Marlowe">
			<section class="about-poster" aria-label="Olly and Santi portrait artwork">
				<div class="about-poster__tiles" aria-hidden="true">
					<figure class="about-poster__tile">
						<img src={ownersPortrait.src} width={ownersPortrait.width} height={ownersPortrait.height} alt="" />
					</figure>
				</div>
				<p class="about-poster__date">Opening September</p>
				<p class="about-poster__title">
					<span class="type-sans">Meet</span>
					<span><em>Olly</em> & <span class="type-sans">Santi</span></span>
				</p>
				<p class="about-poster__address">211 High Street,<br />Christchurch, New Zealand</p>
			</section>

			<section class="about-editorial" aria-label="About Marlowe story">
				<div class="about-editorial__copy">
					<h2>
						Marlowe was founded by Olly Le Maitre and Santiago Burgos, brought together by a shared belief that great hospitality is about making people feel like they're in good hands from the moment they walk through the door.


					</h2>
					<div class="about-editorial__divider" aria-hidden="true"></div>
					<p>
						Opening this September on <span class="type-serif">High Street</span>, Marlowe is an independently owned restaurant celebrating
						exceptional New Zealand produce, thoughtful service, and <span class="type-serif">European-inspired</span> cooking.
					</p>
					<p>
						Alongside the menu, our wine and drinks programme showcases the best of New Zealand and renowned wine
						regions from around the world. Whether you're joining us for a quick glass of wine, a long lunch, or a
						special dinner, our goal is simple: to create a place that feels <span class="type-serif">warm, relaxed,</span> and worth returning to.
					</p>
					<div class="about-editorial__details" aria-label="Contact and careers">
						<h3 class="about-editorial__section-heading"><span>Contact</span> Us</h3>
						<div class="about-editorial__detail">
							<h3>General</h3>
							<p><a href="mailto:santiago@marlowe.co.nz">santiago@marlowe.co.nz</a></p>
						</div>
						<div class="about-editorial__detail">
							<h3>Follow Us</h3>
							<p>
								<a href="https://www.instagram.com/marloweonhigh" target="_blank" rel="noopener noreferrer">
									Instagram
								</a>
							</p>
						</div>
						<div class="about-editorial__detail about-editorial__detail--wide">
							<h3 class="about-editorial__section-heading"><span>Work</span> with us</h3>
							<div class="about-editorial__roles">
								<div>
									<h4>Kitchen</h4>
									<p>
										To enquire about a position with the Marlowe kitchen team, send your CV and a brief cover note to
										<a href="mailto:olly@marlowe.co.nz">olly@marlowe.co.nz</a>
									</p>
								</div>
								<div>
									<h4>Front of House & Bar</h4>
									<p>
										To apply for a role in our service or bar team, send your CV and cover letter to
										<a href="mailto:santi@marlowe.co.nz">santi@marlowe.co.nz</a>
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<span class="about-wordmark" aria-hidden="true"></span>

		<script>
			document.querySelectorAll('[data-about-exit]').forEach((link) => {
				link.addEventListener('click', (event) => {
					const href = link.getAttribute('href');
					if (!href || href.startsWith('mailto:')) return;

					event.preventDefault();
					window.sessionStorage?.setItem('marloweTransition', 'to-home');
					document.body.dataset.aboutExit = 'true';
					window.setTimeout(() => {
						window.location.href = href;
					}, 520);
				});
			});
		</script>
	</body>
</html>
